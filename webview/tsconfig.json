{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "allowJs": false,
    "isolatedModules": true,
    "esModuleInterop": true,
    "types": ["vite/client"]
  },
  "include": ["./**/*.ts", "./**/*.vue", "../src/webviewProtocol.ts", "../src/reviewTypes.ts", "../src/commitDiffUtils.ts"]
}
