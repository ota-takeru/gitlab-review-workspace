{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "gitlab-review: compile",
      "type": "process",
      "command": "npm",
      "args": [
        "run",
        "compile"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "windows": {
        "command": "wsl.exe",
        "args": [
          "bash",
          "-lc",
          "cd \"$(wslpath -u \"$1\")\" && npm run compile",
          "--",
          "${workspaceFolder}"
        ]
      },
      "problemMatcher": [
        "$tsc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
